GEMINI_API_KEY=
TAVILY_API_KEY=

# Prometheux (required — SDK-only Vadalog filter via prometheux_chain)
# 1. Sign up at https://platform.prometheux.ai
# 2. Copy your API token from account settings
PMTX_TOKEN=

# JarvisPy endpoint — set if required by prometheux_chain SDK docs
# Format: https://platform.prometheux.ai/jarvispy/{org}/{username}
JARVISPY_URL=

# Project namespace for save_concept/run_concept (default — no manual project setup)
PMTX_PROJECT_ID=weekend-planner

LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
